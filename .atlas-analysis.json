  "keyFeatures": [
    "Built-in static security analysis that scans every dependency for 17+ suspicious patterns before install",
    "Deterministic dependency resolution via Minimum Version Selection (MVS) inspired by Go Modules",
    "Content-addressed store using SHA-256 hashes — identical packages are never duplicated",
    "Sandboxed script execution using Linux seccomp-BPF with Hermetic, Restricted, and Open profiles",
    "Native package.json support — works with existing npm projects with zero migration",
    "workspace: protocol for monorepo dependency linking via live symlinks",
    "Multiple package sources: npm registry, GitHub, Git, tarball URL, local path, workspace",
    "Interactive security prompts with --non-interactive mode for CI environments"
  ],
  "publicApiSurface": [
    "ara install",
    "ara install --non-interactive",
    "ara install --package-lock",
    "ara add <spec>",
    "ara add --save-dev",
    "ara add --save-peer",
    "ara add --save-optional",
    "ara add --range=caret|patch|exact",
    "ara add --force",
    "ara add --refresh",
    "ara add --offline",
    "ara x <package> [args...]",
    "ara run <script> --profile open|restricted|hermetic|custom",
    "ara analyze [path]",
    "ara audit [path]",
    "ara gc",
    "ara gc --dry-run",
    "ara gc --aggressive"
  ]
}
